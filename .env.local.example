# Local development environment variables.
#
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored.
#
# Loaded by:
#   - Vite (npm run dev / npm run build) — auto-loaded by Vite from .env.local
#   - drizzle.config.ts (npm run db:push / db:migrate / db:generate / db:studio)
# NOT loaded by tests — see .env.test.example for that.
#
# All values are validated at server boot in
# src/server/env/environmentVariablesCreate.ts. See docs/infrastructure.md
# for the full table and docs/architecture/environment.md for the design.

# --- Required (boot fails without them) -------------------------------------

# PostgreSQL connection string for your dev database.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/mydb"

# Name of the cookie that stores the session id. Any URL-safe string; changing
# it after launch logs every existing session out.
sessionCookieName="my-app-session-id"

# Absolute origin of the running site, no trailing slash. Drives canonical
# URLs, hreflang alternates, /sitemap.xml, and /robots.txt — see
# docs/architecture/seo.md.
WEB_PAGE_URL="http://localhost:3000"

# Per-deploy salt mixed into the SHA-256 hash of every visitor request's
# client IP before it lands in Sessions.ipHash. Drives the visitor-chat
# rate limiter — see docs/features/chat-visitor.md#rate-limiting. Generate
# with: openssl rand -hex 32. Rotating it resets the IP bucket for everyone.
VISITOR_IP_HASH_SALT="dev-only-change-me-with-openssl-rand-hex-32"

# --- Capability-specific (required only if you keep the feature) ------------

# Google Generative AI API key. Required by the shipped chat agent
# (src/server/agents/agentUserConversation.ts). Validated when
# serverRuntimeCreate builds the Gemini language model — drop this var if
# you delete chat.
GOOGLE_GENERATIVE_AI_API_KEY=""

# HMAC secret used by src/server/utils/serverToken.ts to sign short-lived
# server-side render tokens. Required by features that call
# serverRuntime.browser.capture against an authenticated /server/* route —
# see docs/architecture/server-side-rendering.md. Drop this var if you
# remove server-side rendering.
SERVER_TOKEN_SECRET=""

# --- Optional ---------------------------------------------------------------

# Set to "true" in production to enable Secure + SameSite=None on the session
# cookie. Leave unset for localhost.
# sessionCookieSecure="false"

# Cookie domain scope for cross-subdomain sessions (e.g. ".example.com").
# Leave unset to scope to the request host only.
# sessionCookieDomainScope=""

# Commit SHA reported by /api/health. In Docker this is set via the BUILD_SHA
# build arg (see Dockerfile). Defaults to "unknown" locally.
# BUILD_SHA=""
